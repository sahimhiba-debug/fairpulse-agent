# API FairPulse — variables d'environnement (PALIER 1).
# Copie ce fichier en .env (git-ignored) et ajuste. Aucun secret réel ici.
# pydantic-settings lit ces variables (priorité : env réelle > .env > défauts du code).

# Adresse d'écoute (localhost uniquement — pas d'exposition réseau).
API_HOST=127.0.0.1
API_PORT=8000

# Garde-fou ressources : jobs max en attente (au-delà -> HTTP 429).
MAX_QUEUE=4

# Device d'inférence : auto -> MPS si dispo (résolu côté serveur MCP).
DEVICE=auto

# --- PALIER 2 : PostgreSQL ---------------------------------------------------
# Identifiants du conteneur Postgres (docker-compose.db.yml les lit) — CHOISIS TON
# propre mot de passe, ne commit jamais ce fichier (.env est git-ignored).
POSTGRES_USER=fairpulse
POSTGRES_PASSWORD=change-me-choisis-un-mot-de-passe
POSTGRES_DB=fairpulse

# URL que l'API utilise pour se connecter. Le mot de passe DOIT être le même que
# POSTGRES_PASSWORD ci-dessus. Si DATABASE_URL est vide -> jobs en mémoire (palier 1).
DATABASE_URL=postgresql+psycopg://fairpulse:change-me-choisis-un-mot-de-passe@localhost:5432/fairpulse

# --- DÉPÔT DÉDIÉ : chemins vers ton checkout FairPulse local ------------------
# Si tu utilises l'agent depuis le dépôt dédié `fairpulse-agent` (et non DANS
# FairPulse), décommente et fais pointer ces variables vers ton FairPulse local
# (le code fairpulse, les poids et les données NE sont PAS dans ce dépôt).
#   FAIRPULSE_ROOT=/chemin/vers/fairpulse           # pour lancer en CLI/uvicorn
#   FAIRPULSE_SRC=/chemin/vers/fairpulse/src/fairpulse     # montage Docker (code)
#   FAIRPULSE_WEIGHTS=/chemin/vers/fairpulse/models/weights
#   FAIRPULSE_DATA=/chemin/vers/fairpulse/data/raw
